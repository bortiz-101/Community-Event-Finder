@startuml
' CommunityEventFinder - Project UML (PlantUML)
' Target: .NET 10 Razor Pages

title CommunityEventFinder - High-level UML

package "Server (.NET Razor Pages)" {
  class Event {
    +string Title
    +string Category
    +string Venue
    +string Address
    +string City
    +string State
    +string Zip
    +DateTime Start
    +DateTime End
    +string Description
    +string? Url
  }

  interface IEventRepository {
    +Add(Event)
    +GetAll()
    +Find(id)
  }

  class EventRepository {
    +Add(Event)
    +GetAll()
    +Find(id)
  }

  class EventService {
    +CreateEvent(Event)
    +GetEvents()
    +ValidateAddress(Event)
  }

  class EventDbContext {
    +DbSet<Event> Events
  }

  class EventsApiController {
    +POST /api/events
    +GET  /api/events
  }

  class IndexModel {
    +OnGet()
    +LoadEvents()
  }

  ' Relationships
  EventRepository ..|> IEventRepository
  EventRepository --> EventDbContext : uses
  EventService --> IEventRepository : uses
  EventsApiController --> EventService : uses
  IndexModel --> EventService : uses
}

package "Client (wwwroot)" {
  rectangle "start.html (UI)" as StartHtml
  rectangle "add.html (popup form)" as AddHtml
  rectangle "app.js (scripts)" as AppJs

  AddHtml --> EventsApiController : HTTP POST /api/events
  StartHtml --> EventsApiController : HTTP GET /api/events
  AddHtml --> StartHtml : window.opener.loadEvents()
  AddHtml --> AppJs : includes/uses
}

' Optional sequence illustrating add flow
== Add Event flow ==
participant "add.html" as Client
participant "EventsApiController" as API
participant "EventService" as Service
participant "EventRepository" as Repo
participant "EventDbContext" as Db

Client -> API : POST /api/events (Event JSON)
API -> Service : CreateEvent(eventDto)
Service -> Repo : Add(Event)
Repo -> Db : SaveChanges()
Db --> Repo : saved
Repo --> Service : persistedEvent
Service --> API : createdEvent / status
API --> Client : 200 OK / error

@enduml
