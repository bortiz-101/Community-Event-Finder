<?xml version="1.0" encoding="utf-8"?>
<ProjectDiagram name="CommunityEventFinder" framework=".NET 10" type="Razor Pages">
  <Description>High-level XML diagram of the project structure and key runtime interactions.</Description>

  <Folders>
    <Folder name="Pages"/>
    <Folder name="wwwroot">
      <File name="add.html" role="Client: Add event form" />
      <File name="start.html" role="Client: Main UI / listing" />
      <File name="app.js" role="Client: shared JS" />
    </Folder>
    <Folder name="Api">
      <File name="Events API" role="Server: POST /api/events (stores/validates Event)" />
    </Folder>
    <Folder name="Models">
      <File name="Event" role="Server: domain model" />
    </Folder>
  </Folders>

  <Model name="Event">
    <Property name="title" type="string"/>
    <Property name="category" type="string"/>
    <Property name="venue" type="string"/>
    <Property name="address" type="string"/>
    <Property name="city" type="string"/>
    <Property name="state" type="string"/>
    <Property name="zip" type="string"/>
    <Property name="start" type="DateTime"/>
    <Property name="end" type="DateTime"/>
    <Property name="desc" type="string"/>
    <Property name="url" type="string" nullable="true"/>
  </Model>

  <Endpoints>
    <Endpoint path="/api/events" method="POST" description="Receives JSON payload from `add.html` and creates an `Event` record"/>
  </Endpoints>

  <Interactions>
    <Interaction from="wwwroot/add.html" to="/api/events" type="HTTP POST">
      <Note>JSON keys: title, category, venue, address, city, state, zip, start, end, desc, url</Note>
    </Interaction>

    <Interaction from="wwwroot/add.html" to="wwwroot/start.html" type="WindowOpener">
      <Note>On successful save, `add.html` calls `window.opener.loadEvents()` if present and then closes itself</Note>
    </Interaction>

    <Interaction from="wwwroot/start.html" to="Api/Events API" type="HTTP GET /polling" optional="true">
      <Note>UI page loads events and may call backend to fetch list</Note>
    </Interaction>

    <Interaction from="wwwroot/app.js" to="wwwroot/start.html" type="SharedJS">
      <Note>Contains shared client logic such as `loadEvents` (if implemented)</Note>
    </Interaction>
  </Interactions>

  <Notes>
    <Note>Adjust paths and API controller names to match your server code (this diagram reflects items discovered in `wwwroot/add.html` and common Razor Pages layout).</Note>
  </Notes>
</ProjectDiagram>
